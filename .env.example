# ⚠️  WARNING: Never commit the .env file to version control!
# If your token was ever exposed, revoke it immediately via @BotFather on Telegram.

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Anthropic API Key (from https://console.anthropic.com/)
# Required for claude-agent-sdk to authenticate with the Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Allowed Telegram user IDs (comma-separated, empty = allow all users)
# Find your user ID by messaging @userinfobot on Telegram
# Example: ALLOWED_USER_IDS=123456789,987654321
ALLOWED_USER_IDS=

# Base directory for auto-created projects (default: ~/Downloads/)
CLAUDE_PROJECTS_DIR=~/Downloads

# Max conversation turns per session (default: 20)
MAX_TURNS_PER_CYCLE=20

# Max budget in USD per session (default: 5)
MAX_BUDGET_USD=5

# Agent timeout in seconds (default: 300)
AGENT_TIMEOUT_SECONDS=300

# SDK: max agentic turns per single query (default: 10)
SDK_MAX_TURNS_PER_QUERY=10

# SDK: max budget per single query in USD (default: 2.0)
SDK_MAX_BUDGET_PER_QUERY=2.0

# Session expiry in hours (default: 24)
SESSION_EXPIRY_HOURS=24

# Conversation store / session DB directory (default: ./data)
CONVERSATION_STORE_DIR=./data
