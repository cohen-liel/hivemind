# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Claude CLI path (default: "claude" - assumes it's in PATH)
CLAUDE_CLI_PATH=claude

# Base directory for auto-created projects (default: ~/claude-projects/)
CLAUDE_PROJECTS_DIR=~/claude-projects

# Max conversation turns per session (default: 20)
MAX_TURNS_PER_CYCLE=20

# Max budget in USD per session (default: 5)
MAX_BUDGET_USD=5

# Agent timeout in seconds (default: 300)
AGENT_TIMEOUT_SECONDS=300

# Conversation store directory (default: ~/telegram-claude-bot/data)
CONVERSATION_STORE_DIR=~/Downloads/telegram-claude-bot/data
